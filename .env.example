# Copy this file to .env.local and fill in your real registry values.

# Required: target registry hostname, e.g. ghcr.io or registry.example.com
IMAGE_REGISTRY=registry.example.com

# Optional: namespace / organization in the registry
IMAGE_NAMESPACE=your-team

# Optional: repository name in the registry
IMAGE_NAME=youtube-to-mp4

# Optional: build platforms for buildx
PLATFORMS=linux/amd64,linux/arm64

# Optional: buildx builder name
BUILDER_NAME=multiarch-builder

# Optional: docker build context and Dockerfile path
BUILD_CONTEXT=.
DOCKERFILE_PATH=Dockerfile

# Optional: app environment passed as build arg
APP_ENV=production

# Optional: tag override used by scripts/deploy.sh
# IMAGE_TAG=1.0.0-prod

# Optional: whether deploy-latest.sh also pushes a version tag
ALSO_TAG_VERSION=true

# Optional: set true to print the final docker buildx command without pushing
DRY_RUN=false
